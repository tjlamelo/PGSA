@{
    ViewData["Title"] = "Connexion";
}

<h2>Connexion</h2>

<form method="post" asp-action="IndexPost" asp-controller="Login">
    <div class="mb-3">
        <label class="form-label">Username ou Email</label>
        <input class="form-control" name="usernameOrEmail" />
    </div>
    <div class="mb-3">
        <label class="form-label">Mot de passe</label>
        <input class="form-control" type="password" name="password" />
    </div>
    <div>
        <button class="btn btn-primary" type="submit">Se connecter</button>
    </div>

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="text-danger mt-2">
            @foreach (var m in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
                <div>@m.ErrorMessage</div>
            }
        </div>
    }
</form>
